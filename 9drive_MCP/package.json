{
  "name": "9drive-mcp",
  "version": "1.0.0",
  "description": "MCP Server para 9Drive - Almacenamiento unificado Google Drive + S3",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "dev:sse": "tsx src/index.ts --transport sse",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "seed": "tsx src/seed.ts"
  },
  "keywords": ["mcp", "google-drive", "s3", "storage", "self-hosted"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@prisma/client": "^6.9.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/lib-storage": "^3.700.0",
    "googleapis": "^144.0.0",
    "zod": "^3.24.0",
    "dotenv": "^16.4.0",
    "mime-types": "^2.1.35"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/mime-types": "^2.1.4",
    "prisma": "^6.9.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
