# ═══════════════════════════════════════════════════
# 9Drive MCP Server - Configuración
# ═══════════════════════════════════════════════════

# Base de datos (MySQL o SQLite)
# MySQL:
DATABASE_URL="mysql://root:password@localhost:3306/9drive_mcp"
# SQLite (alternativa sin config):
# DATABASE_URL="file:./9drive.db"

# ═══════════════════════════════════════════════════
# Transporte MCP
# ═══════════════════════════════════════════════════
# Opciones: "stdio" | "sse"
MCP_TRANSPORT="stdio"
# Puerto para SSE (solo si MCP_TRANSPORT=sse)
MCP_PORT=3500

# ═══════════════════════════════════════════════════
# Google Drive OAuth2
# ═══════════════════════════════════════════════════
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3500/oauth/google/callback"

# ═══════════════════════════════════════════════════
# Cifrado de tokens (exactamente 32 caracteres)
# ═══════════════════════════════════════════════════
TOKEN_ENCRYPTION_KEY="cambia-esta-clave-de-32-chars!!"

# ═══════════════════════════════════════════════════
# S3 Compatible Storage (opcional)
# ═══════════════════════════════════════════════════
# Se pueden agregar múltiples cuentas S3 vía las tools del MCP
# Ejemplo para MinIO local:
# S3_ENDPOINT="http://localhost:9000"
# S3_ACCESS_KEY="minioadmin"
# S3_SECRET_KEY="minioadmin"
# S3_BUCKET="9drive"
# S3_REGION="us-east-1"

# ═══════════════════════════════════════════════════
# Políticas de subida
# ═══════════════════════════════════════════════════
# Opciones: "most-available" | "round-robin" | "priority-order"
UPLOAD_POLICY="most-available"
# Tamaño máximo de archivo (5GB por defecto)
MAX_UPLOAD_BYTES=5368709120
